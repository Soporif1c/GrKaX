# Keep shell scripts and the Gradle wrapper LF so they run on the Linux CI runner
*.sh text eol=lf
gradlew text eol=lf
*.bat text eol=crlf

# Normalize source to LF in the repo
*.kt text eol=lf
*.kts text eol=lf
*.xml text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.pro text eol=lf
*.properties text eol=lf

# Binary
*.jar binary
*.aar binary
*.dat binary
*.png binary
*.jks binary
